# Core runtime
ARCADIA_MODE=local
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/arcadia
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
AUTH_FRONTEND_URL=https://your-frontend-domain.vercel.app

# Request limits / rate limits
MAX_UPLOAD_SIZE_MB=25
MAX_CODE_PAYLOAD_MB=2
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_PER_WINDOW=20
RATE_LIMIT_CHAT_PER_WINDOW=60
RATE_LIMIT_QUIZ_PER_WINDOW=60
RATE_LIMIT_UPLOAD_PER_WINDOW=15
RATE_LIMIT_CODE_RUN_PER_WINDOW=20

# Auth + SMTP
AUTH_REQUIRE_EMAIL_VERIFICATION=true
AUTH_EMAIL_OTP_EXPIRES_MINUTES=10
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Google OAuth (optional)
# Backend support is ready; set these to enable provider buttons.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPES=openid email profile

# Google Calendar (optional)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events

# Azure mode (optional)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_REASONING_EFFORT=medium
AZURE_FORM_RECOGNIZER_ENDPOINT=
AZURE_FORM_RECOGNIZER_KEY=
AZURE_FORM_RECOGNIZER_MODEL=prebuilt-read
AZURE_FORM_RECOGNIZER_API_VERSION=2023-07-31
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
